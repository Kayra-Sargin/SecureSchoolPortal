@model BitirmeProjesiPortal.Models.ClassReference

@{
    ViewData["Title"] = "Sınıf Oluştur";
}

<style>
    .content-card {
        background-color: #161b22;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 32px;
        width: 100%;
        max-width: 600px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        margin-top: 10px;
    }

        .content-card h1 {
            color: #c9d1d9;
            font-size: 1.75rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .content-card hr {
            border-color: #30363d;
            margin-bottom: 24px;
        }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group .control-label {
            color: #8b949e;
            margin-bottom: 8px;
            font-weight: 500;
            display: block;
        }

    .textBox {
        background-color: #0d1117 !important;
        border: 1px solid #30363d;
        color: #c9d1d9 !important;
        border-radius: 6px;
        padding: 10px;
    }

        .textBox:focus {
            background-color: #0d1117;
            border-color: #58a6ff;
            box-shadow: 0 0 0 3px rgba(88, 166, 255, 0.3);
            outline: none;
        }

    select[multiple].textBox option {
        padding: 6px 10px;
        margin-bottom: 2px;
        border-radius: 4px;
    }

        select[multiple].textBox option:checked {
            background-color: #1f6feb linear-gradient(0deg, #1f6feb 0%, #1f6feb 100%);
            color: #ffffff;
        }

    .actionBtn {
        background-color: #1f6feb;
        color: #ffffff;
        border: 1px solid rgba(240, 246, 252, 0.1);
        border-radius: 6px;
        padding: 10px 24px;
        font-weight: 600;
        transition: background-color 0.2s ease-in-out;
    }

        .actionBtn:hover {
            background-color: #388bfd;
            color: #ffffff;
        }

    .secondaryBtn {
        background-color: #21262d;
        color: #c9d1d9;
        border: 1px solid #30363d;
        border-radius: 6px;
        padding: 10px 24px;
        font-weight: 600;
        text-decoration: none;
        transition: background-color 0.2s, color 0.2s;
        display: inline-block;
    }

        .secondaryBtn:hover {
            background-color: #30363d;
            color: #ffffff;
        }

    .sys-message {
        background-color: rgba(35, 134, 54, 0.1);
        border: 1px solid #238636;
        color: #3fb950;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 20px;
        font-weight: 500;
    }
</style>

<div class="row">
    <div class="col-12 d-flex justify-content-center">
        <div class="content-card">

            <form asp-action="Create">
                <h1><i class="bi bi-folder-plus text-primary"></i> Sınıf Oluştur (Create Class)</h1>
                <hr />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @if (ViewBag.Message != null)
                {
                    <div class="sys-message">
                        <i class="bi bi-check-circle"></i> @ViewBag.Message
                    </div>
                }

                <input type="hidden" asp-for="UserId" />

                <div class="form-group mb-3">
                    <label asp-for="CRN" class="control-label"></label>
                    <input asp-for="CRN" class="form-control textBox" placeholder="Örn: 10425" />
                    <span asp-validation-for="CRN" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="ClassId" class="control-label">Ders Kodu (Class Code)</label>
                    <select asp-for="ClassId" class="form-select textBox" asp-items="@(new SelectList(ViewBag.ClassList, "Id", "ClassName"))">
                        <option value="">-- Seçiniz (Select) --</option>
                    </select>
                    <span asp-validation-for="ClassId" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label class="control-label">Öğrencileri Seçin <small class="text-muted">(Hold Ctrl/Cmd to select multiple)</small></label>
                    <select name="SelectedStudentIds" class="form-select textBox" multiple="multiple" style="height: 180px;" asp-items="ViewBag.StudentList">
                    </select>
                </div>

                <div class="form-group d-flex gap-2 mt-4">
                    <button type="submit" class="actionBtn">
                        <i class="bi bi-save"></i> Kaydet (Save)
                    </button>
                    <a asp-action="Index" asp-route-userId="@Model.UserId" class="secondaryBtn">
                        <i class="bi bi-arrow-left"></i> Listeye Dön
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}