@model BitirmeProjesiPortal.Models.ClassReference

@{
    ViewData["Title"] = "Sınıfı Düzenle";
}

<style>
    .content-card {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-top: 4px solid transparent;
        background-clip: padding-box;
        border-radius: 8px;
        padding: 32px;
        width: 100%;
        max-width: 600px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        margin-top: 10px;
        position: relative;
    }

        .content-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(135deg, #f59e0b, #d97706);
            border-top-left-radius: 8px;
            border-top-right-radius: 8px;
        }

        .content-card h2 {
            color: #1e293b;
            font-size: 1.75rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .content-card hr {
            border-color: #e2e8f0;
            margin-bottom: 24px;
        }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group .control-label {
            color: #334155;
            margin-bottom: 8px;
            font-weight: 500;
            display: block;
        }

    .textBox {
        background-color: #ffffff;
        color: #1e293b;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        padding: 10px;
        transition: border-color 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .textBox:focus {
            border-color: #f59e0b;
            box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.2);
            outline: none;
        }

    select[multiple].textBox option {
        padding: 8px 12px;
        margin-bottom: 2px;
        border-radius: 4px;
        color: #1e293b;
        transition: background-color 0.1s;
    }

        select[multiple].textBox option:checked {
            background: linear-gradient(135deg, #f59e0b, #d97706);
            color: #ffffff;
        }

    .updateBtn {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: #ffffff;
        border: none;
        border-radius: 6px;
        padding: 10px 24px;
        font-weight: 600;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
        box-shadow: 0 4px 6px rgba(245, 158, 11, 0.2);
    }

        .updateBtn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 12px rgba(245, 158, 11, 0.3);
            color: #ffffff;
        }

    .secondaryBtn {
        background-color: #f1f5f9;
        color: #475569;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        padding: 10px 24px;
        font-weight: 600;
        text-decoration: none;
        transition: background-color 0.2s, color 0.2s, border-color 0.2s;
        display: inline-block;
    }

        .secondaryBtn:hover {
            background-color: #e2e8f0;
            color: #0f172a;
            border-color: #94a3b8;
        }

    .sys-message {
        background-color: #ecfdf5;
        border: 1px solid #a7f3d0;
        color: #047857;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 20px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
    }
</style>

<div class="row">
    <div class="col-12 d-flex justify-content-center">
        <div class="content-card">

            <form method="post" asp-action="Edit">
                <h2>
                    <i class="bi bi-pencil-square" style="color: #f59e0b;"></i>
                    Sınıfı Düzenle (Edit Class)
                </h2>
                <hr />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @if (ViewBag.Message != null)
                {
                    <div class="sys-message">
                        <i class="bi bi-check-circle-fill" style="font-size: 1.1rem;"></i> @ViewBag.Message
                    </div>
                }

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="UserId" />

                <div class="form-group mb-3">
                    <label asp-for="CRN" class="control-label"></label>
                    <input asp-for="CRN" class="form-control textBox" placeholder="Örn: 10425" />
                    <span asp-validation-for="CRN" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="ClassId" class="control-label">Ders Kodu (Class Code)</label>
                    <select asp-for="ClassId" class="form-select textBox" asp-items="@(new SelectList(ViewBag.ClassList, "Id", "ClassName"))">
                        <option value="">-- Seçiniz (Select) --</option>
                    </select>
                    <span asp-validation-for="ClassId" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label class="control-label">Öğrencileri Seçin <small style="color: #64748b;">(Hold Ctrl/Cmd to select multiple)</small></label>
                    <select name="SelectedStudentIds" class="form-select textBox" multiple="multiple" style="height: 180px;" asp-items="ViewBag.StudentList">
                    </select>
                </div>

                <div class="form-group d-flex gap-3 mt-4">
                    <button type="submit" class="updateBtn">
                        <i class="bi bi-save2"></i> Güncelle (Update)
                    </button>
                    <a asp-controller="ClassReference" asp-action="Index" class="secondaryBtn">
                        <i class="bi bi-arrow-left"></i> Listeye Dön
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}