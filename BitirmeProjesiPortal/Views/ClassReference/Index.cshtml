@model IEnumerable<BitirmeProjesiPortal.Models.ClassReference>

@{
    ViewData["Title"] = "Class List";
}

<style>
    .page-header {
        color: #c9d1d9;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .createBtn {
        background-color: #1f6feb;
        color: #ffffff;
        border: 1px solid rgba(240, 246, 252, 0.1);
        border-radius: 6px;
        padding: 8px 16px;
        font-weight: 600;
        transition: background-color 0.2s ease-in-out;
        text-decoration: none;
        display: inline-block;
    }

        .createBtn:hover {
            background-color: #388bfd;
            color: #ffffff;
        }

    .table-container {
        background-color: #161b22;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 16px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        overflow-x: auto;
    }

    .dark-table {
        color: #c9d1d9;
        margin-bottom: 0;
    }

        .dark-table th {
            background-color: #21262d;
            color: #8b949e;
            border-bottom: 2px solid #30363d;
            border-top: none;
            font-weight: 600;
            padding: 12px;
        }

        .dark-table td {
            background-color: transparent;
            border-bottom: 1px solid #30363d;
            vertical-align: middle;
            padding: 12px;
        }

        .dark-table tbody tr {
            transition: background-color 0.15s ease-in-out;
        }

            .dark-table tbody tr:hover {
                background-color: #21262d;
            }

    .moduleBtn {
        background-color: #21262d;
        color: #c9d1d9;
        border: 1px solid #30363d;
        border-radius: 6px;
        padding: 6px 12px;
        font-size: 0.85rem;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .moduleBtn:hover {
            background-color: #30363d;
            color: #58a6ff;
            border-color: #58a6ff;
        }

    .editBtn {
        background-color: #d29922;
        color: #ffffff;
        border: none;
        border-radius: 6px;
        padding: 6px 12px;
        font-size: 0.85rem;
        transition: background-color 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .editBtn:hover {
            background-color: #e3b341;
            color: #ffffff;
        }

    .deleteBtn {
        background-color: #da3633;
        color: #ffffff;
        border: none;
        border-radius: 6px;
        padding: 6px 12px;
        font-size: 0.85rem;
        transition: background-color 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .deleteBtn:hover {
            background-color: #f85149;
            color: #ffffff;
        }

    .modal-content {
        background-color: #161b22;
        color: #c9d1d9;
        border: 1px solid #30363d;
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.6);
        border-radius: 8px;
    }

    .modal-header {
        border-bottom: 1px solid #30363d;
    }

    .modal-footer {
        border-top: 1px solid #30363d;
    }

    .btn-close {
        filter: invert(1) grayscale(100%) brightness(200%);
    }

    .btn-secondary {
        background-color: #21262d;
        color: #c9d1d9;
        border: 1px solid #30363d;
    }

        .btn-secondary:hover {
            background-color: #30363d;
            color: #ffffff;
        }
</style>

<div class="container p-3">
    <div class="row pt-4 mb-4 align-items-center">
        <div class="col-6">
            <h2 class="page-header"><i class="bi bi-mortarboard-fill text-primary"></i> Class Hub</h2>
        </div>
        <div class="col-6 text-end">
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="ClassReference" asp-action="Create" asp-route-userId="@ViewBag.UserId" class="createBtn">
                    <i class="bi bi-plus-lg"></i> Create New Class
                </a>
            }
        </div>
    </div>

    <div class="table-container">
        <table class="table dark-table text-center" style="width:100%">
            <thead>
                <tr>
                    <th class="text-start pl-3">Class Name</th>
                    <th>CRN</th>
                    <th>Class Modules & Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var obj in Model)
                {
                    <tr>
                        <td class="text-start fw-bold align-middle pl-3">
                            @obj.Class.ClassName
                        </td>
                        <td class="align-middle">
                            <span class="badge bg-secondary text-light font-monospace" style="font-size: 0.9rem;">@obj.CRN</span>
                        </td>
                        <td>
                            <div class="d-flex justify-content-center gap-2 flex-wrap">
                                <a asp-controller="Announcement" asp-action="Index" asp-route-classReferenceId="@obj.Id" class="moduleBtn">
                                    <i class="bi bi-megaphone"></i> Announcements
                                </a>
                                <a asp-controller="Assignment" asp-action="Index" asp-route-classReferenceId="@obj.Id" class="moduleBtn">
                                    <i class="bi bi-journal-check"></i> Assignments
                                </a>
                                <a asp-controller="ClassFile" asp-action="Index" asp-route-classReferenceId="@obj.Id" class="moduleBtn">
                                    <i class="bi bi-folder2-open"></i> Class Files
                                </a>

                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-controller="Grade" asp-action="Index" asp-route-classReferenceId="@obj.Id" class="moduleBtn" style="border-color: #238636;">
                                        <i class="bi bi-file-check" style="color: #3fb950;"></i> Grades
                                    </a>
                                    <a asp-controller="ClassReference" asp-action="Edit" asp-route-id="@obj.Id" class="editBtn">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <button class="deleteBtn" onclick="PrepareDelete(@obj.Id, '@obj.CRN')">
                                        <i class="bi bi-trash-fill"></i> Delete
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Warning!</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to permanently delete this class and all its associated data?</p>
                <div class="p-2 border border-secondary rounded font-monospace text-center" style="background-color: #0d1117;">
                    <strong id="displayCrn" class="text-light"></strong>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="deleteBtn" id="confirm-delete" onclick="DeleteClassReference()">
                    <i class="bi bi-trash"></i> Confirm Delete
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let classReferenceId = null;

        function PrepareDelete(id, crn) {
            classReferenceId = id;
            $("#displayCrn").text("CRN: " + crn);
            $("#deleteModal").modal('show');
        }

        function DeleteClassReference() {
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Delete", "ClassReference")',
                data: { id: classReferenceId },
                success: function () {
                    location.reload();
                },
                error: function () {
                    alert("The class could not be deleted. Try again.");
                }
            });
            $("#deleteModal").modal('hide');
        }
    </script>
}