@model IEnumerable<BitirmeProjesiPortal.Models.ClassFile>

@{
    ViewData["Title"] = "Class File List";
}

<style>
    .page-header {
        color: #c9d1d9;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .createBtn {
        background-color: #1f6feb;
        color: #ffffff;
        border: 1px solid rgba(240, 246, 252, 0.1);
        border-radius: 6px;
        padding: 8px 16px;
        font-weight: 600;
        transition: background-color 0.2s ease-in-out;
        text-decoration: none;
        display: inline-block;
    }

        .createBtn:hover {
            background-color: #388bfd;
            color: #ffffff;
        }

    .table-container {
        background-color: #161b22;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 16px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        overflow-x: auto;
    }

    .dark-table {
        color: #c9d1d9;
        margin-bottom: 0;
    }

        .dark-table th {
            background-color: #21262d;
            color: #8b949e;
            border-bottom: 2px solid #30363d;
            border-top: none;
            font-weight: 600;
            padding: 12px;
        }

        .dark-table td {
            background-color: transparent;
            border-bottom: 1px solid #30363d;
            vertical-align: middle;
            padding: 12px;
        }

        .dark-table tbody tr {
            transition: background-color 0.15s ease-in-out;
        }

            .dark-table tbody tr:hover {
                background-color: #21262d;
            }

    .downloadBtn {
        background-color: #238636;
        color: #ffffff;
        border: none;
        border-radius: 6px;
        padding: 6px 12px;
        font-size: 0.9rem;
        transition: background-color 0.2s;
        text-decoration: none;
    }

        .downloadBtn:hover {
            background-color: #2ea043;
            color: #ffffff;
        }

    .editBtn {
        background-color: #d29922;
        color: #ffffff;
        border: none;
        border-radius: 6px;
        padding: 6px 12px;
        font-size: 0.9rem;
        transition: background-color 0.2s;
        text-decoration: none;
    }

        .editBtn:hover {
            background-color: #e3b341;
            color: #ffffff;
        }

    .deleteBtn {
        background-color: #da3633;
        color: #ffffff;
        border: none;
        border-radius: 6px;
        padding: 6px 12px;
        font-size: 0.9rem;
        transition: background-color 0.2s;
    }

        .deleteBtn:hover {
            background-color: #f85149;
            color: #ffffff;
        }

    .modal-content {
        background-color: #161b22;
        color: #c9d1d9;
        border: 1px solid #30363d;
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.6);
        border-radius: 8px;
    }

    .modal-header {
        border-bottom: 1px solid #30363d;
    }

    .modal-footer {
        border-top: 1px solid #30363d;
    }

    .btn-close {
        filter: invert(1) grayscale(100%) brightness(200%);
    }

    .btn-secondary {
        background-color: #21262d;
        color: #c9d1d9;
        border: 1px solid #30363d;
    }

        .btn-secondary:hover {
            background-color: #30363d;
            color: #ffffff;
        }
</style>

<div class="container p-3">
    <div class="row pt-4 mb-4 align-items-center">
        <div class="col-6">
            <h2 class="page-header"><i class="bi bi-folder2-open text-primary"></i> Class File List</h2>
        </div>
        <div class="col-6 text-end">
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="ClassFile" asp-action="Create" asp-route-classReferenceId="@ViewBag.ClassReferenceId" class="createBtn">
                    <i class="bi bi-cloud-arrow-up"></i> Upload a File
                </a>
            }
        </div>
    </div>

    <div class="table-container">
        <table class="table dark-table text-center" style="width:100%">
            <thead>
                <tr>
                    <th>Class Name</th>
                    <th>CRN</th>
                    <th>File</th>
                    <th>Upload Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var obj in Model)
                {
                    <tr>
                        <td>
                            @obj.ClassReference?.Class?.ClassName
                        </td>
                        <td>
                            <span class="badge bg-secondary text-light font-monospace">@obj.ClassReference?.CRN</span>
                        </td>
                        <td class="text-start font-monospace" style="font-size: 0.9rem;">
                            <i class="bi bi-file-earmark-text text-muted"></i> @obj.FilePath
                        </td>
                        <td>
                            @obj.UploadDate.ToString("yyyy-MM-dd HH:mm")
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a asp-controller="ClassFile" asp-action="Download" asp-route-fileName="@obj.FilePath" class="downloadBtn mx-1">
                                    <i class="bi bi-download"></i> Download
                                </a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <button class="deleteBtn mx-1" onclick="PrepareDelete(@obj.Id, '@obj.FilePath')">
                                        <i class="bi bi-trash-fill"></i> Delete
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Warning!</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to permanently delete this file?</p>
                <div class="p-2 border border-secondary rounded font-monospace text-break" style="background-color: #0d1117;">
                    <strong id="displayHeader" class="text-light"></strong>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="deleteBtn" id="confirm-delete" onclick="DeleteClassFile()">
                    <i class="bi bi-trash"></i> Confirm Delete
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let classFileId = null;

        function PrepareDelete(id, header) {
            classFileId = id;
            $("#displayHeader").text(header);
            $("#deleteModal").modal('show');
        }

        function DeleteClassFile() {
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Delete", "ClassFile")',
                data: { id: classFileId },
                success: function () {
                    location.reload();
                },
                error: function () {
                    alert("The file could not be deleted. Try again.");
                }
            });
            $("#deleteModal").modal('hide');
        }
    </script>
}