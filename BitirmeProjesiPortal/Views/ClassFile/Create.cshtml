@model BitirmeProjesiPortal.Models.ClassFile

@{
    ViewData["Title"] = "Upload Class File";
}

<style>
    .content-card {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-top: 4px solid transparent;
        background-clip: padding-box;
        border-radius: 8px;
        padding: 32px;
        width: 100%;
        max-width: 500px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        margin-top: 10px;
        position: relative;
    }

        .content-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(135deg, #3b82f6, #20c997);
            border-top-left-radius: 8px;
            border-top-right-radius: 8px;
        }

        .content-card h1 {
            color: #1e293b;
            font-size: 1.75rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .content-card hr {
            border-color: #e2e8f0;
            margin-bottom: 24px;
        }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group .control-label {
            color: #334155;
            margin-bottom: 8px;
            font-weight: 500;
            display: block;
        }

    .file-upload {
        background-color: #ffffff;
        border: 1px dashed #3b82f6;
        color: #475569;
        border-radius: 6px;
        padding: 16px 8px;
        width: 100%;
        transition: border-color 0.2s;
    }

        .file-upload:hover {
            border-color: #2563eb;
        }

        .file-upload::file-selector-button {
            background-color: #f1f5f9;
            color: #475569;
            border: 1px solid #cbd5e1;
            padding: 6px 14px;
            border-radius: 4px;
            margin-right: 16px;
            font-weight: 500;
            cursor: pointer;
            transition: background-color 0.2s, color 0.2s;
        }

            .file-upload::file-selector-button:hover {
                background-color: #e2e8f0;
                color: #1e293b;
            }

    .actionBtn {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: #ffffff;
        border: none;
        border-radius: 6px;
        padding: 10px 24px;
        font-weight: 600;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
        width: 100%;
        box-shadow: 0 4px 6px rgba(37, 99, 235, 0.2);
    }

        .actionBtn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 12px rgba(37, 99, 235, 0.3);
            color: #ffffff;
        }

    .sys-message {
        background-color: #ecfdf5;
        border: 1px solid #a7f3d0;
        color: #047857;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 20px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .backBtn {
        display: inline-block;
        margin-top: 24px;
        color: #64748b;
        text-decoration: none;
        transition: color 0.2s;
        font-weight: 500;
    }

        .backBtn:hover {
            color: #3b82f6;
        }
</style>

<div class="row">
    <div class="col-12 d-flex justify-content-center">
        <div class="content-card">
            <h1><i class="bi bi-cloud-arrow-up" style="color: #3b82f6;"></i> Upload Class File</h1>
            <hr />

            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @if (ViewBag.Message != null)
                {
                    <div class="sys-message">
                        <i class="bi bi-check-circle-fill"></i> @ViewBag.Message
                    </div>
                }

                <input type="hidden" asp-for="ClassReferenceId" />

                <div class="form-group mb-4">
                    <label asp-for="File" class="control-label">Select Document / Material</label>
                    <input type="file" asp-for="File" class="file-upload" />
                    <span asp-validation-for="File" class="text-danger"></span>
                </div>

                <div class="form-group mt-3">
                    <button type="submit" class="actionBtn">
                        <i class="bi bi-upload"></i> Upload to Server
                    </button>
                </div>
            </form>

            <div>
                <a asp-action="Index" asp-route-classReferenceId="@Model.ClassReferenceId" class="backBtn">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}