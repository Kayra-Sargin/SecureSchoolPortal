@model BitirmeProjesiPortal.Models.Grade

@{
    ViewData["Title"] = "Not Gir";
}

<h2 class="text-primary">Enter Grade</h2>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ClassReferenceId" />

            <div class="form-group mb-3">
                <label asp-for="StudentId" class="control-label fw-bold">Student</label>
                <select asp-for="StudentId" id="StudentId" class="form-select" asp-items="ViewBag.Students">
                    <option value="">-- Select Student --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ExamTypeId" class="control-label fw-bold">Exam Type</label>
                <select asp-for="ExamTypeId" class="form-select" asp-items="ViewBag.ExamTypes">
                    <option value="">-- Select Exam Type --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="GradeBy100" class="control-label fw-bold">Grade</label>
                <input asp-for="GradeBy100" id="GradeBy100" type="number" class="form-control" />
            </div>

            <div class="form-group mb-4">
                <label asp-for="Comment" class="control-label fw-bold text-danger">Teacher's Comment</label>
                <textarea asp-for="Comment" id="CommentInput" class="form-control" rows="3" placeholder="Öğrenciye iletilecek yorumu buraya yazın..."></textarea>
            </div>

            <div class="form-group">
                <input type="submit" value="Submit" class="btn btn-primary" />
            </div>
        </form>
    </div>

    <div class="col-md-7">
        <div class="card border-info">
            <div class="card-header bg-info text-white">
                <i class="bi bi-envelope"></i> E-posta Önizleme Sistemi
            </div>
            <div class="card-body">
                <p class="text-muted small">Öğrenciye gidecek mail şablonu. <strong>{{YORUM}}</strong> alanı, sol taraftaki öğretmen yorumu ile otomatik değiştirilir.</p>

                <div class="form-group">
                    <textarea id="emailTemplateInput" class="form-control bg-light" rows="5" style="font-family: monospace;" readonly>Merhaba [Öğrenci Adı],

Sınav notunuz: [Sınav Notu]

Öğretmeninizin Mesajı:
{{YORUM}}

İyi çalışmalar.</textarea>
                </div>

                <button type="button" class="btn btn-outline-info mt-3" onclick="generatePreview()">Mail Önizlemesini Gör</button>

                <div id="previewContainer" class="mt-3 p-3 bg-light border rounded" style="display: none;">
                    <strong>Gönderilecek E-posta:</strong>
                    <pre id="previewOutput" class="mb-0 mt-2" style="white-space: pre-wrap; font-family: inherit; font-size: 14px;"></pre>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function generatePreview() {
            const gradeValue = document.getElementById('GradeBy100').value || "0";
            const commentText = document.getElementById('CommentInput').value;
            const templateText = document.getElementById('emailTemplateInput').value;

            const studentSelect = document.getElementById('StudentId');
            let studentName = "Ali Yılmaz";
            if (studentSelect && studentSelect.selectedIndex > 0) {
                studentName = studentSelect.options[studentSelect.selectedIndex].text;
            }

            const previewContainer = document.getElementById('previewContainer');
            const previewOutput = document.getElementById('previewOutput');

            previewContainer.style.display = 'block';
            previewOutput.innerHTML = '<span class="text-muted">Önizleme yükleniyor...</span>';

            try {
                const response = await fetch('/Grade/PreviewEmailVulnerable', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        Template: templateText,
                        StudentName: studentName,
                        Grade: gradeValue,
                        CommentText: commentText
                    })
                });

                const data = await response.json();

                if (data.success) {
                    previewOutput.innerText = data.preview;
                    previewContainer.className = 'mt-3 p-3 bg-light border border-success rounded';
                } else {
                    previewOutput.innerText = data.error;
                    previewContainer.className = 'mt-3 p-3 bg-white border border-danger rounded text-danger';
                }
            } catch (error) {
                previewOutput.innerText = "Sunucuya bağlanılamadı.";
            }
        }
    </script>
}