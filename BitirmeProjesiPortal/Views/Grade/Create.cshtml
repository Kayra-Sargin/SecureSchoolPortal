@model BitirmeProjesiPortal.Models.Grade

@{
    ViewData["Title"] = "Not Gir";
}

<style>
    .page-header {
        color: #c9d1d9;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 24px;
        margin-top: 10px;
    }

    .content-card {
        background-color: #161b22;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 28px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        height: 100%;
    }

        .content-card h3 {
            color: #c9d1d9;
            font-size: 1.4rem;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .content-card hr {
            border-color: #30363d;
            margin-bottom: 24px;
        }

    .form-group {
        margin-bottom: 20px;
    }

    .control-label {
        color: #8b949e;
        margin-bottom: 8px;
        font-weight: 500;
        display: block;
    }

        .control-label.text-danger {
            color: #ff7b72 !important;
        }

    .textBox {
        background-color: #0d1117 !important;
        border: 1px solid #30363d;
        color: #c9d1d9 !important;
        border-radius: 6px;
        padding: 10px;
        width: 100%;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .textBox:focus {
            background-color: #0d1117;
            border-color: #58a6ff;
            box-shadow: 0 0 0 3px rgba(88, 166, 255, 0.3);
            outline: none;
        }

        .textBox[readonly] {
            background-color: #21262d !important;
            color: #8b949e !important;
            border-color: #30363d;
            cursor: not-allowed;
            font-family: monospace;
            font-size: 0.95rem;
        }

    .actionBtn {
        background-color: #1f6feb;
        color: #ffffff;
        border: 1px solid rgba(240, 246, 252, 0.1);
        border-radius: 6px;
        padding: 10px 24px;
        font-weight: 600;
        transition: background-color 0.2s ease-in-out;
        width: 100%;
    }

        .actionBtn:hover {
            background-color: #388bfd;
            color: #ffffff;
        }

    .previewBtn {
        background-color: transparent;
        color: #58a6ff;
        border: 1px solid #58a6ff;
        border-radius: 6px;
        padding: 8px 16px;
        font-weight: 500;
        transition: all 0.2s ease;
        width: 100%;
    }

        .previewBtn:hover {
            background-color: #58a6ff;
            color: #ffffff;
        }

    .preview-box {
        margin-top: 20px;
        padding: 16px;
        background-color: #0d1117;
        border: 1px solid #30363d;
        border-radius: 6px;
        color: #c9d1d9;
        display: none;
    }

        .preview-box.success-state {
            border-color: #238636;
            background-color: rgba(35, 134, 54, 0.05);
        }

        .preview-box.error-state {
            border-color: #da3633;
            background-color: rgba(218, 54, 51, 0.05);
            color: #ff7b72;
        }

    .text-muted {
        color: #8b949e !important;
    }
</style>

<h2 class="page-header"><i class="bi bi-file-check-fill text-primary"></i> Enter Grade</h2>

<div class="row align-items-stretch">
    <div class="col-md-5 mb-4 mb-md-0">
        <div class="content-card">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="ClassReferenceId" />

                <div class="form-group">
                    <label asp-for="StudentId" class="control-label"><i class="bi bi-person"></i> Student</label>
                    <select asp-for="StudentId" id="StudentId" class="form-select textBox" asp-items="ViewBag.Students">
                        <option value="">-- Select Student --</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="ExamTypeId" class="control-label"><i class="bi bi-card-text"></i> Exam Type</label>
                    <select asp-for="ExamTypeId" class="form-select textBox" asp-items="ViewBag.ExamTypes">
                        <option value="">-- Select Exam Type --</option>
                    </select>
                </div>

                <div class="form-group">
                    <label asp-for="GradeBy100" class="control-label"><i class="bi bi-123"></i> Grade</label>
                    <input asp-for="GradeBy100" id="GradeBy100" type="number" class="form-control textBox" />
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Comment" class="control-label text-danger"><i class="bi bi-chat-left-text"></i> Teacher's Comment</label>
                    <textarea asp-for="Comment" id="CommentInput" class="form-control textBox" rows="3" placeholder="Öğrenciye iletilecek yorumu buraya yazın..."></textarea>
                </div>

                <div class="form-group mt-auto">
                    <button type="submit" class="actionBtn">
                        <i class="bi bi-check2-circle"></i> Submit Grade
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="col-md-7">
        <div class="content-card" style="border-color: #1f6feb;">
            <h3><i class="bi bi-envelope text-primary"></i> E-posta Önizleme Sistemi</h3>
            <hr />

            <p class="text-muted small mb-3">
                <i class="bi bi-info-circle"></i> Öğrenciye gidecek mail şablonu.
                <strong class="text-light">{{YORUM}}</strong> alanı, sol taraftaki öğretmen yorumu ile otomatik değiştirilir.
            </p>

            <div class="form-group">
                <textarea id="emailTemplateInput" class="form-control textBox" rows="6" readonly>Merhaba [Öğrenci Adı],

Sınav notunuz: [Sınav Notu]

Öğretmeninizin Mesajı:
{{YORUM}}

İyi çalışmalar.</textarea>
            </div>

            <button type="button" class="previewBtn mt-2" onclick="generatePreview()">
                <i class="bi bi-eye"></i> Mail Önizlemesini Gör
            </button>

            <div id="previewContainer" class="preview-box">
                <strong class="d-block mb-2 text-light border-bottom border-secondary pb-2">
                    <i class="bi bi-send"></i> Gönderilecek E-posta:
                </strong>
                <pre id="previewOutput" class="mb-0 mt-2" style="white-space: pre-wrap; font-family: monospace; font-size: 14px;"></pre>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function generatePreview() {
            const gradeValue = document.getElementById('GradeBy100').value || "0";
            const commentText = document.getElementById('CommentInput').value;

            const studentSelect = document.getElementById('StudentId');
            let studentName = "Ali Yılmaz";
            if (studentSelect && studentSelect.selectedIndex > 0) {
                studentName = studentSelect.options[studentSelect.selectedIndex].text;
            }

            const previewContainer = document.getElementById('previewContainer');
            const previewOutput = document.getElementById('previewOutput');

            previewContainer.style.display = 'block';
            previewContainer.className = 'preview-box';
            previewOutput.innerHTML = '<span class="text-muted"><i class="bi bi-hourglass-split"></i> Önizleme yükleniyor...</span>';

            try {
                const response = await fetch('@Url.Action("PreviewEmailSecure", "Grade")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        StudentName: studentName,
                        Grade: gradeValue,
                        CommentText: commentText
                    })
                });

                const data = await response.json();

                if (data.success) {
                    previewOutput.innerText = data.preview;
                    previewContainer.className = 'preview-box success-state';
                } else {
                    previewOutput.innerText = data.error;
                    previewContainer.className = 'preview-box error-state';
                }
            } catch (error) {
                previewOutput.innerText = "Sunucuya bağlanılamadı.";
                previewContainer.className = 'preview-box error-state';
            }
        }
    </script>
}