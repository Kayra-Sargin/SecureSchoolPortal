@model IEnumerable<BitirmeProjesiPortal.Models.Grade>

@{
    ViewData["Title"] = "Grade List";
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Grade List</h2>
        </div>
        <div class="col-6 text-end">
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Grade" asp-action="Create" asp-route-classReferenceId="@ViewBag.ClassReferenceId" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> &nbsp; Enter New Grade
                </a>
            }
        </div>
    </div>
    <br /><br />

    <table class="table table-bordered table-striped text-center" style="width:100%">
        <thead>
            <tr>
                <th>Class Name</th>
                <th>Student</th>
                <th>Exam Type</th>
                <th>Grade</th>
                <th>Comment</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var obj in Model)
            {
                <tr>
                    <td>
                        @obj.ClassReference?.Class?.ClassName
                    </td>
                    <td>
                        @obj.Student?.UserName
                    </td>
                    <td>
                        @obj.ExamType?.ExamTypeName
                    </td>
                    <td>
                        @obj.GradeBy100
                    </td>
                    <td>
                        @obj.Comment
                    </td>
                    <td>
                        <div class="btn-group" role="group">
                            @if (User.IsInRole("Admin"))
                            {
                                <button class="btn btn-danger"
                                        data-id="@obj.Id"
                                        data-student="@obj.Student?.UserName"
                                        data-grade="@obj.GradeBy100"
                                        onclick="PrepareDelete(this)">
                                    <i class="bi bi-trash-fill"></i> Delete
                                </button>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title text-danger">Warning!</h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this grade?<br />
                <strong id="displayInfo"></strong>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirm-delete" onclick="DeleteGrade()">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let gradeId = null;

        function PrepareDelete(element) {
            gradeId = element.getAttribute("data-id");
            let studentName = element.getAttribute("data-student");
            let gradeScore = element.getAttribute("data-grade");

            $("#displayInfo").text("Student: " + studentName + " | Grade: " + gradeScore);
            $("#deleteModal").modal('show');
        }

        function DeleteGrade() {
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Delete", "Grade")',
                data: { id: gradeId },
                success: function () {
                    location.reload();
                },
                error: function () {
                    alert("The grade could not be deleted. Try again.");
                }
            });
            $("#deleteModal").modal('hide');
        }
    </script>
}