@model IEnumerable<BitirmeProjesiPortal.Models.Grade>

@{
    ViewData["Title"] = "Grade List";
}

<style>
    .page-header {
        color: #c9d1d9;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .createBtn {
        background-color: #1f6feb;
        color: #ffffff;
        border: 1px solid rgba(240, 246, 252, 0.1);
        border-radius: 6px;
        padding: 8px 16px;
        font-weight: 600;
        transition: background-color 0.2s ease-in-out;
        text-decoration: none;
        display: inline-block;
    }

        .createBtn:hover {
            background-color: #388bfd;
            color: #ffffff;
        }

    .table-container {
        background-color: #161b22;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 16px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        overflow-x: auto;
    }

    .dark-table {
        color: #c9d1d9;
        margin-bottom: 0;
    }

        .dark-table th {
            background-color: #21262d;
            color: #8b949e;
            border-bottom: 2px solid #30363d;
            border-top: none;
            font-weight: 600;
            padding: 12px;
        }

        .dark-table td {
            background-color: transparent;
            border-bottom: 1px solid #30363d;
            vertical-align: middle;
            padding: 12px;
        }

        .dark-table tbody tr {
            transition: background-color 0.15s ease-in-out;
        }

            .dark-table tbody tr:hover {
                background-color: #21262d;
            }

    .deleteBtn {
        background-color: #da3633;
        color: #ffffff;
        border: none;
        border-radius: 6px;
        padding: 6px 12px;
        font-size: 0.9rem;
        transition: background-color 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .deleteBtn:hover {
            background-color: #f85149;
            color: #ffffff;
        }

    .modal-content {
        background-color: #161b22;
        color: #c9d1d9;
        border: 1px solid #30363d;
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.6);
        border-radius: 8px;
    }

    .modal-header {
        border-bottom: 1px solid #30363d;
    }

    .modal-footer {
        border-top: 1px solid #30363d;
    }

    .btn-close {
        filter: invert(1) grayscale(100%) brightness(200%);
    }

    .btn-secondary {
        background-color: #21262d;
        color: #c9d1d9;
        border: 1px solid #30363d;
    }

        .btn-secondary:hover {
            background-color: #30363d;
            color: #ffffff;
        }
</style>

<div class="container p-3">
    <div class="row pt-4 mb-4 align-items-center">
        <div class="col-6">
            <h2 class="page-header"><i class="bi bi-file-check text-primary"></i> Grade List</h2>
        </div>
        <div class="col-6 text-end">
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Grade" asp-action="Create" asp-route-classReferenceId="@ViewBag.ClassReferenceId" class="createBtn">
                    <i class="bi bi-plus-lg"></i> Enter New Grade
                </a>
            }
        </div>
    </div>

    <div class="table-container">
        <table class="table dark-table text-center" style="width:100%">
            <thead>
                <tr>
                    <th>Class Name</th>
                    <th>Student</th>
                    <th>Exam Type</th>
                    <th>Grade</th>
                    <th class="text-start">Comment</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var obj in Model)
                {
                    <tr>
                        <td>
                            @obj.ClassReference?.Class?.ClassName
                        </td>
                        <td class="font-monospace text-light">
                            <i class="bi bi-person-fill text-muted"></i> @obj.Student?.UserName
                        </td>
                        <td>
                            <span class="badge bg-secondary text-light">@obj.ExamType?.ExamTypeName</span>
                        </td>
                        <td class="fw-bold" style="font-size: 1.1rem; color: #58a6ff;">
                            @obj.GradeBy100
                        </td>
                        <td class="text-start text-muted fst-italic">
                            @if (!string.IsNullOrEmpty(obj.Comment))
                            {
                                <span>"</span>
                                @obj.Comment
                        
                                <span>"</span>
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                @if (User.IsInRole("Admin"))
                                {
                                    <button class="deleteBtn mx-1"
                                            data-id="@obj.Id"
                                            data-student="@obj.Student?.UserName"
                                            data-grade="@obj.GradeBy100"
                                            onclick="PrepareDelete(this)">
                                        <i class="bi bi-trash-fill"></i> Delete
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Warning!</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to permanently delete this grade?</p>
                <div class="p-2 border border-secondary rounded text-center" style="background-color: #0d1117;">
                    <strong id="displayInfo" class="text-light font-monospace"></strong>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="deleteBtn" id="confirm-delete" onclick="DeleteGrade()">
                    <i class="bi bi-trash"></i> Confirm Delete
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let gradeId = null;

        function PrepareDelete(element) {
            gradeId = element.getAttribute("data-id");
            let studentName = element.getAttribute("data-student");
            let gradeScore = element.getAttribute("data-grade");

            $("#displayInfo").text(studentName + " | Grade: " + gradeScore);
            $("#deleteModal").modal('show');
        }

        function DeleteGrade() {
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Delete", "Grade")',
                data: { id: gradeId },
                success: function () {
                    location.reload();
                },
                error: function () {
                    alert("The grade could not be deleted. Try again.");
                }
            });
            $("#deleteModal").modal('hide');
        }
    </script>
}