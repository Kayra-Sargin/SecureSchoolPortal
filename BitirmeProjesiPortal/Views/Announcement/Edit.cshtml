@model BitirmeProjesiPortal.Models.Announcement

@{
    ViewData["Title"] = "Edit Announcement";
}

<style>
    .content-card {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-top: 4px solid transparent;
        background-clip: padding-box;
        border-radius: 8px;
        padding: 32px;
        width: 100%;
        max-width: 600px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        margin-top: 10px;
        position: relative;
    }

        .content-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(135deg, #f59e0b, #d97706);
            border-top-left-radius: 8px;
            border-top-right-radius: 8px;
        }

        .content-card h2 {
            color: #1e293b;
            font-size: 1.75rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .content-card hr {
            border-color: #e2e8f0;
            margin-bottom: 24px;
        }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group .control-label {
            color: #334155;
            margin-bottom: 8px;
            font-weight: 500;
            display: block;
        }

    .textBox {
        background-color: #ffffff !important;
        border: 1px solid #cbd5e1;
        color: #1e293b !important;
        border-radius: 6px;
        padding: 10px;
        transition: border-color 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .textBox:focus {
            border-color: #f59e0b;
            box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.2);
            outline: none;
        }

    .updateBtn {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: #ffffff;
        border: none;
        border-radius: 6px;
        padding: 10px 24px;
        font-weight: 600;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
        width: 100%;
        box-shadow: 0 4px 6px rgba(245, 158, 11, 0.2);
    }

        .updateBtn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 12px rgba(245, 158, 11, 0.3);
            color: #ffffff;
        }

    .sys-message {
        background-color: #ecfdf5;
        border: 1px solid #a7f3d0;
        color: #047857;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 20px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .backBtn {
        display: inline-block;
        margin-top: 24px;
        color: #64748b;
        text-decoration: none;
        transition: color 0.2s;
        font-weight: 500;
    }

        .backBtn:hover {
            color: #d97706;
        }
</style>

<div class="row">
    <div class="col-12 d-flex justify-content-center">
        <div class="content-card">

            <form method="post" asp-action="Edit">
                <h2>
                    <i class="bi bi-pencil-square" style="color: #f59e0b;"></i> Edit Announcement
                </h2>
                <hr />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @if (ViewBag.Message != null)
                {
                    <div class="sys-message">
                        <i class="bi bi-check-circle-fill"></i> @ViewBag.Message
                    </div>
                }

                <input type="hidden" asp-for="ClassReferenceId" />

                <div class="form-group">
                    <label asp-for="Header" class="control-label"></label>
                    <input asp-for="Header" class="form-control textBox" />
                    <span asp-validation-for="Header" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Content" class="control-label"></label>
                    <textarea asp-for="Content" class="form-control textBox" rows="6"></textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="updateBtn">
                        <i class="bi bi-save2"></i> Update Record
                    </button>
                </div>

                <div>
                    <a asp-action="Index" asp-route-classReferenceId="@Model.ClassReferenceId" class="backBtn">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}