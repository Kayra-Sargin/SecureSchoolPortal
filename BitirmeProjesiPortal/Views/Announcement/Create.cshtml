@model BitirmeProjesiPortal.Models.Announcement

@{
    ViewData["Title"] = "Create Announcement";
}

<style>
    .content-card {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-top: 4px solid transparent;
        background-clip: padding-box;
        border-radius: 8px;
        padding: 32px;
        width: 100%;
        max-width: 600px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        margin-top: 10px;
        position: relative;
    }

        .content-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(135deg, #3b82f6, #20c997);
            border-top-left-radius: 8px;
            border-top-right-radius: 8px;
        }

        .content-card h1 {
            color: #1e293b;
            font-size: 1.75rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .content-card hr {
            border-color: #e2e8f0;
            margin-bottom: 24px;
        }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group .control-label {
            color: #334155;
            margin-bottom: 8px;
            font-weight: 500;
            display: block;
        }

    .textBox {
        background-color: #ffffff !important;
        border: 1px solid #cbd5e1;
        color: #1e293b !important;
        border-radius: 6px;
        padding: 10px;
        transition: border-color 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .textBox:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
            outline: none;
        }

    .actionBtn {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: #ffffff;
        border: none;
        border-radius: 6px;
        padding: 10px 24px;
        font-weight: 600;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
        width: 100%;
        box-shadow: 0 4px 6px rgba(37, 99, 235, 0.2);
    }

        .actionBtn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 12px rgba(37, 99, 235, 0.3);
            color: #ffffff;
        }

    .sys-message {
        background-color: #ecfdf5;
        border: 1px solid #a7f3d0;
        color: #047857;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 20px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .backBtn {
        display: inline-block;
        margin-top: 24px;
        color: #64748b;
        text-decoration: none;
        transition: color 0.2s;
        font-weight: 500;
    }

        .backBtn:hover {
            color: #3b82f6;
        }
</style>

<div class="row">
    <div class="col-12 d-flex justify-content-center">
        <div class="content-card">
            <h1><i class="bi bi-megaphone" style="color: #3b82f6;"></i> Create Announcement</h1>
            <hr />

            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @if (ViewBag.Message != null)
                {
                    <div class="sys-message">
                        <i class="bi bi-check-circle-fill"></i> @ViewBag.Message
                    </div>
                }

                <input type="hidden" asp-for="ClassReferenceId" />

                <div class="form-group">
                    <label asp-for="Header" class="control-label"></label>
                    <input asp-for="Header" class="form-control textBox" placeholder="Enter announcement title..." />
                    <span asp-validation-for="Header" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Content" class="control-label"></label>
                    <textarea asp-for="Content" class="form-control textBox" rows="6" placeholder="Write the announcement details here..."></textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="actionBtn">
                        <i class="bi bi-send-fill"></i> Publish Announcement
                    </button>
                </div>
            </form>

            <div>
                <a asp-action="Index" asp-route-classReferenceId="@Model.ClassReferenceId" class="backBtn">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}