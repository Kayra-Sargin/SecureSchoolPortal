@model IEnumerable<BitirmeProjesiPortal.Models.Announcement>

@{
    ViewData["Title"] = "Index";
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Announcement List</h2>
        </div>
        <div class="col-6 text-end">
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Announcement" asp-action="Create" asp-route-classReferenceId="@ViewBag.ClassReferenceId" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> &nbsp; Create New Announcement
                </a>
            }
        </div>
    </div>
    <br /><br />

    <table class="table table-bordered table-striped text-center" style="width:100%">
        <thead>
            <tr>
                <th>Class Name</th>
                <th>CRN</th>
                <th>Header</th>
                <th>Content</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var obj in Model)
            {
                <tr>
                    <td>
                        @obj.ClassReference.Class.ClassName
                    </td>
                    <td>
                        @obj.ClassReference.CRN
                    </td>
                    <td>
                        @Html.Raw(obj.Header)
                    </td>
                    <td>
                        @Html.Raw(obj.Content)
                    </td>
                    <td>
                        <div class="btn-group" role="group">
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Announcement" asp-action="Edit" asp-route-id="@obj.Id" class="btn btn-primary mx-2">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <button class="btn btn-danger" onclick="PrepareDelete(@obj.Id, '@obj.Header')">
                                    <i class="bi bi-trash-fill"></i> Delete
                                </button>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Warning!</h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this announcement?<br />
                <strong id="displayHeader"></strong>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirm-delete" onclick="DeleteAnnouncement()">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let announcementId = null;

        function PrepareDelete(id, header) {
            announcementId = id;
            $("#displayHeader").text("Header: " + header);
            $("#deleteModal").modal('show');
        }

        function DeleteAnnouncement() {
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Delete", "Announcement")',
                data: { id: announcementId },
                success: function () {
                    location.reload();
                },
                error: function () {
                    alert("The announcement could not be deleted. Try again.");
                }
            });
            $("#deleteModal").modal('hide');
        }
    </script>
}