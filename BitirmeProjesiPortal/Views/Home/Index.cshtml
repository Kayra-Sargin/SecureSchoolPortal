@{
    ViewData["Title"] = "Home Page";
}

<style>
    .welcome-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 65vh;
    }

    .welcome-card {
        background-color: #161b22;
        border: 1px solid #30363d;
        border-radius: 12px;
        padding: 60px 40px;
        text-align: center;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5);
        width: 100%;
        max-width: 700px;
        position: relative;
        overflow: hidden;
    }

        .welcome-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, #1f6feb, #58a6ff);
        }

    .welcome-icon {
        font-size: 4rem;
        color: #58a6ff;
        margin-bottom: 20px;
        display: inline-block;
        filter: drop-shadow(0 0 12px rgba(88, 166, 255, 0.4));
    }

    .welcome-card h1 {
        color: #c9d1d9;
        font-weight: 700;
        letter-spacing: -0.5px;
        margin-bottom: 0;
    }

    .welcome-name {
        color: #58a6ff;
        text-shadow: 0 0 10px rgba(88, 166, 255, 0.3);
    }

    .welcome-subtitle {
        color: #8b949e;
        font-size: 1.15rem;
        margin-top: 15px;
        font-weight: 500;
    }
</style>

<div class="welcome-container">
    <div class="welcome-card">
        <i class="bi bi-shield-check welcome-icon"></i>

        <h1 class="display-4">Welcome, <span class="welcome-name">@ViewBag.Name</span></h1>

        <p class="welcome-subtitle">
            Bitirme Projesi Portal | Secure Access Terminal
        </p>
    </div>
</div>