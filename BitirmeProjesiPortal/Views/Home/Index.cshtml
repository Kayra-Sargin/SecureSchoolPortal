@{
    ViewData["Title"] = "Home Page";
}

<style>
    .welcome-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 65vh;
    }

    .welcome-card {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 60px 40px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        width: 100%;
        max-width: 700px;
        position: relative;
        overflow: hidden;
    }

        .welcome-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(135deg, #3b82f6, #20c997);
        }

    .welcome-icon {
        font-size: 4rem;
        color: #3b82f6;
        margin-bottom: 20px;
        display: inline-block;
        filter: drop-shadow(0 4px 6px rgba(59, 130, 246, 0.2));
    }

    .welcome-card h1 {
        color: #1e293b;
        font-weight: 700;
        letter-spacing: -0.5px;
        margin-bottom: 0;
    }

    .welcome-name {
        background: linear-gradient(135deg, #3b82f6, #20c997);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .welcome-subtitle {
        color: #64748b;
        font-size: 1.15rem;
        margin-top: 15px;
        font-weight: 500;
    }
</style>

<div class="welcome-container">
    <div class="welcome-card">
        <i class="bi bi-shield-check welcome-icon"></i>

        <h1 class="display-4">Welcome, <span class="welcome-name">@ViewBag.Name</span></h1>

        <p class="welcome-subtitle">
            Bitirme Projesi Portal | Secure Access Terminal
        </p>
    </div>
</div>