 @if (Context.User.Identity.Name != null){
     <form asp-controller="Account" asp-action="Logout" method="post" id="LogOutForm" class="navbar-right">
         <ul class="nav navbar-nav navbar-right">
             <li>
                <button type="button" class="btn disabled">
                    Hello @Context.User.Identity.Name!
                    @if (Context.User.IsInRole("Admin"))
                    {
                        <span style="background-color: red; color: white; padding: 3px 6px; border-radius: 4px; margin-left: 5px; font-weight: bold;">
                            ÖĞRETMEN
                        </span>
                    }
                </button>
             </li>
             <li>
                 <button type="submit" class="btn btn-link navbar-btn navbar-link text-dark">Log off</button>
             </li>
         </ul>
     </form>
 }
else
{
    <ul class="nav navbar-nav navbar-right">
        <li><a class="nav-link text-dark" asp-controller="Account" asp-action="Registration">Registration</a></li>
        <li><a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Log in</a></li>
    </ul>
}