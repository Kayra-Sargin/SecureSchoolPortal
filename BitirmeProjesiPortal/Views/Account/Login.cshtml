@model BitirmeProjesiPortal.ViewModel.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<style>
    .login-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 60vh;
    }

    .login-card {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-top: 4px solid transparent;
        background-clip: padding-box;
        border-radius: 8px;
        padding: 32px;
        width: 100%;
        max-width: 400px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        position: relative;
    }

        .login-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(135deg, #10b981, #059669);
            border-top-left-radius: 8px;
            border-top-right-radius: 8px;
        }

        .login-card h1 {
            color: #1e293b;
            font-size: 1.75rem;
            text-align: center;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .login-card hr {
            border-color: #e2e8f0;
            margin-bottom: 24px;
        }

    .form-group {
        margin-bottom: 16px;
    }

        .form-group .control-label {
            color: #334155;
            margin-bottom: 8px;
            font-weight: 500;
            display: block;
        }

    .textBox {
        background-color: #ffffff;
        color: #1e293b;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        height: 44px;
        transition: border-color 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .textBox:focus {
            border-color: #10b981;
            box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.2);
            outline: none;
        }

    .loginBtn {
        width: 100%;
        background: linear-gradient(135deg, #10b981, #059669);
        color: #ffffff;
        border: none;
        border-radius: 6px;
        height: 44px;
        font-weight: 600;
        margin-top: 10px;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
        box-shadow: 0 4px 6px rgba(16, 185, 129, 0.2);
    }

        .loginBtn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 12px rgba(16, 185, 129, 0.3);
            color: #ffffff;
        }

    .auth-links {
        text-align: center;
        margin-top: 24px;
        color: #64748b;
        font-size: 0.9rem;
    }

        .auth-links a {
            color: #3b82f6;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }

            .auth-links a:hover {
                color: #2563eb;
                text-decoration: underline;
            }
</style>

<div class="row login-wrapper">
    <div class="login-card">
        <h1><i class="bi bi-shield-lock" style="color: #10b981;"></i> Login</h1>
        <hr />

        <form asp-action="Login">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group">
                <label asp-for="UserNameOrEmail" class="control-label"></label>
                <input asp-for="UserNameOrEmail" class="form-control textBox" autocomplete="username" />
                <span asp-validation-for="UserNameOrEmail" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="control-label"></label>
                <input asp-for="Password" class="form-control textBox" type="password" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="loginBtn">Login</button>
            </div>
        </form>

        <div class="auth-links">
            Don't have an account? <br />
            <a asp-action="Registration">Go To Registration</a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}