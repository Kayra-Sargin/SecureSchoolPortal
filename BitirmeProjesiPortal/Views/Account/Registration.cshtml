@model BitirmeProjesiPortal.ViewModel.RegistrationViewModel

@{
    ViewData["Title"] = "Registration";
}

<style>
    .auth-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
        padding-top: 20px;
    }

    .auth-card {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-top: 4px solid transparent;
        background-clip: padding-box;
        border-radius: 8px;
        padding: 32px;
        width: 100%;
        max-width: 450px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        position: relative;
    }

        .auth-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(135deg, #3b82f6, #20c997);
            border-top-left-radius: 8px;
            border-top-right-radius: 8px;
        }

        .auth-card h1 {
            color: #1e293b;
            font-size: 1.75rem;
            text-align: center;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .auth-card hr {
            border-color: #e2e8f0;
            margin-bottom: 24px;
        }

    .form-group {
        margin-bottom: 16px;
    }

        .form-group .control-label {
            color: #334155;
            margin-bottom: 8px;
            font-weight: 500;
            display: block;
        }

    .textBox {
        background-color: #ffffff !important;
        color: #1e293b;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        height: 44px;
        transition: border-color 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .textBox:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
            outline: none;
        }

    .registerBtn {
        width: 100%;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: #ffffff;
        border: none;
        border-radius: 6px;
        height: 44px;
        font-weight: 600;
        margin-top: 10px;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
        box-shadow: 0 4px 6px rgba(37, 99, 235, 0.2);
    }

        .registerBtn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 12px rgba(37, 99, 235, 0.3);
            color: #ffffff;
        }

    .sys-message {
        background-color: #ecfdf5;
        border: 1px solid #a7f3d0;
        color: #047857;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 20px;
        text-align: center;
        font-weight: 500;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .auth-links {
        text-align: center;
        margin-top: 24px;
        color: #64748b;
        font-size: 0.9rem;
    }

        .auth-links a {
            color: #3b82f6;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }

            .auth-links a:hover {
                color: #2563eb;
                text-decoration: underline;
            }
</style>

<div class="row auth-wrapper">
    <div class="auth-card">
        <h1><i class="bi bi-person-plus" style="color: #3b82f6;"></i> Create Profile</h1>
        <hr />

        <form asp-action="Registration">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            @if (ViewBag.Message != null)
            {
                <div class="sys-message">
                    <i class="bi bi-check-circle-fill"></i> @ViewBag.Message
                </div>
            }

            <div class="form-group">
                <label asp-for="FirstName" class="control-label"></label>
                <input asp-for="FirstName" class="form-control textBox" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="LastName" class="control-label"></label>
                <input asp-for="LastName" class="form-control textBox" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="UserName" class="control-label"></label>
                <input asp-for="UserName" class="form-control textBox" autocomplete="username" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="control-label"></label>
                <input asp-for="Email" class="form-control textBox" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password" class="control-label"></label>
                <input asp-for="Password" class="form-control textBox" type="password" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="registerBtn">Register</button>
            </div>
        </form>

        <div class="auth-links">
            Already have an account? <br />
            <a asp-action="Login">Go To Login</a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}