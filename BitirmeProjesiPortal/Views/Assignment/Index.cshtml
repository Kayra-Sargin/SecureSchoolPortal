@model IEnumerable<BitirmeProjesiPortal.Models.Assignment>

@{
    ViewData["Title"] = "Assignment List";
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">Assignment List</h2>
        </div>
        <div class="col-6 text-end">
            @if (User.IsInRole("Admin"))
            {
                <a asp-controller="Assignment" asp-action="Create" asp-route-classReferenceId="@ViewBag.ClassReferenceId" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> &nbsp; Create New Assignment
                </a>
            }
        </div>
    </div>
    <br /><br />

    <table class="table table-bordered table-striped text-center" style="width:100%">
        <thead>
            <tr>
                <th>Class Name</th>
                <th>CRN</th>
                <th>Header</th>
                <th>Content</th>
                <th>File</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var obj in Model)
            {
                <tr>
                    <td>
                        @obj.ClassReference?.Class?.ClassName
                    </td>
                    <td>
                        @obj.ClassReference?.CRN
                    </td>
                    <td>
                        @obj.Header
                    </td>
                    <td>
                        @obj.Content
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(obj.AnswerFilePath))
                        {
                            <a href="@obj.AnswerFilePath" target="_blank" class="btn btn-sm btn-info">
                                <i class="bi bi-file-earmark-arrow-down"></i> Download
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No File</span>
                        }
                    </td>
                    <td>
                        <div class="btn-group" role="group">
                            <a asp-controller="Assignment" asp-action="Edit" asp-route-id="@obj.Id" class="btn btn-primary mx-2">
                                <i class="bi bi-pencil-square"></i> Edit
                            </a>
                            @if (User.IsInRole("Admin"))
                            {
                                <button class="btn btn-danger" onclick="PrepareDelete(@obj.Id, '@obj.Header')">
                                    <i class="bi bi-trash-fill"></i> Delete
                                </button>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h3 class="modal-title">Warning!</h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this assignment?<br />
                <strong id="displayHeader"></strong>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirm-delete" onclick="DeleteAssignment()">Delete</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let assignmentId = null;

        function PrepareDelete(id, header) {
            assignmentId = id;
            $("#displayHeader").text("Header: " + header);
            $("#deleteModal").modal('show');
        }

        function DeleteAssignment() {
            $.ajax({
                type: 'POST',
                url: '@Url.Action("Delete", "Assignment")',
                data: { id: assignmentId },
                success: function () {
                    location.reload();
                },
                error: function () {
                    alert("The assignment could not be deleted. Try again.");
                }
            });
            $("#deleteModal").modal('hide');
        }
    </script>
}