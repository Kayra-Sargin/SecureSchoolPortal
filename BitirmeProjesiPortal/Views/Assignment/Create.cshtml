@model BitirmeProjesiPortal.Models.Assignment

@{
    ViewData["Title"] = "Create Assignment";
}

<style>
    .content-card {
        background-color: #161b22;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 32px;
        width: 100%;
        max-width: 600px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        margin-top: 10px;
    }

        .content-card h1 {
            color: #c9d1d9;
            font-size: 1.75rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .content-card hr {
            border-color: #30363d;
            margin-bottom: 24px;
        }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group .control-label {
            color: #8b949e;
            margin-bottom: 8px;
            font-weight: 500;
            display: block;
        }

    .textBox {
        background-color: #0d1117 !important;
        border: 1px solid #30363d;
        color: #c9d1d9 !important;
        border-radius: 6px;
        padding: 10px;
    }

        .textBox:focus {
            background-color: #0d1117;
            border-color: #58a6ff;
            box-shadow: 0 0 0 3px rgba(88, 166, 255, 0.3);
            outline: none;
        }

    .file-upload {
        background-color: #0d1117;
        border: 1px dashed #58a6ff;
        color: #8b949e;
        border-radius: 6px;
        padding: 8px;
        width: 100%;
        transition: border-color 0.2s;
    }

        .file-upload:hover {
            border-color: #79c0ff;
        }

        .file-upload::file-selector-button {
            background-color: #21262d;
            color: #c9d1d9;
            border: 1px solid #30363d;
            padding: 6px 14px;
            border-radius: 4px;
            margin-right: 16px;
            font-weight: 500;
            cursor: pointer;
            transition: background-color 0.2s, color 0.2s;
        }

            .file-upload::file-selector-button:hover {
                background-color: #30363d;
                color: #ffffff;
            }

    .actionBtn {
        background-color: #1f6feb;
        color: #ffffff;
        border: 1px solid rgba(240, 246, 252, 0.1);
        border-radius: 6px;
        padding: 10px 24px;
        font-weight: 600;
        transition: background-color 0.2s ease-in-out;
        width: 100%;
    }

        .actionBtn:hover {
            background-color: #388bfd;
            color: #ffffff;
        }

    .sys-message {
        background-color: rgba(35, 134, 54, 0.1);
        border: 1px solid #238636;
        color: #3fb950;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 20px;
        font-weight: 500;
    }

    .backBtn {
        display: inline-block;
        margin-top: 24px;
        color: #8b949e;
        text-decoration: none;
        transition: color 0.2s;
        font-weight: 500;
    }

        .backBtn:hover {
            color: #58a6ff;
        }
</style>

<div class="row">
    <div class="col-12 d-flex justify-content-center">
        <div class="content-card">
            <h1><i class="bi bi-file-earmark-plus text-primary"></i> Create Assignment</h1>
            <hr />

            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @if (ViewBag.Message != null)
                {
                    <div class="sys-message">
                        <i class="bi bi-check-circle"></i> @ViewBag.Message
                    </div>
                }

                <input type="hidden" asp-for="ClassReferenceId" />

                <div class="form-group mb-3">
                    <label asp-for="Header" class="control-label"></label>
                    <input asp-for="Header" class="form-control textBox" placeholder="Enter assignment title..." />
                    <span asp-validation-for="Header" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Content" class="control-label"></label>
                    <textarea asp-for="Content" class="form-control textBox" rows="4" placeholder="Describe the assignment requirements..."></textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="AnswerFile" class="control-label"><i class="bi bi-cloud-upload"></i> Upload Assignment File</label>
                    <input type="file" asp-for="AnswerFile" class="file-upload" />
                    <span asp-validation-for="AnswerFile" class="text-danger"></span>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="actionBtn">
                        <i class="bi bi-send-fill"></i> Publish Assignment
                    </button>
                </div>
            </form>

            <div>
                <a asp-action="Index" asp-route-classReferenceId="@Model.ClassReferenceId" class="backBtn">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}