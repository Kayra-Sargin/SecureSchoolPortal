@model BitirmeProjesiPortal.Models.Assignment

@{
    ViewData["Title"] = User.IsInRole("Admin") ? "Edit Assignment" : "Submit Assignment";
    bool isAdmin = User.IsInRole("Admin");
}

<style>
    .content-card {
        background-color: #161b22;
        border: 1px solid #30363d;
        border-radius: 8px;
        padding: 32px;
        width: 100%;
        max-width: 650px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
        margin-top: 10px;
    }

        .content-card h2 {
            color: #c9d1d9;
            font-size: 1.75rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .content-card hr {
            border-color: #30363d;
            margin-bottom: 24px;
        }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group .control-label {
            color: #8b949e;
            margin-bottom: 8px;
            font-weight: 500;
            display: block;
        }

    .textBox {
        background-color: #0d1117 !important;
        border: 1px solid #30363d;
        color: #c9d1d9 !important;
        border-radius: 6px;
        padding: 10px;
    }

        .textBox:focus {
            background-color: #0d1117;
            border-color: #58a6ff;
            box-shadow: 0 0 0 3px rgba(88, 166, 255, 0.3);
            outline: none;
        }

    .read-only-box {
        background-color: #0d1117;
        border: 1px solid #30363d;
        color: #c9d1d9;
        border-radius: 6px;
        padding: 12px;
        font-size: 0.95rem;
        line-height: 1.5;
    }

    .file-upload {
        background-color: #0d1117;
        border: 1px dashed #58a6ff;
        color: #8b949e;
        border-radius: 6px;
        padding: 8px;
        width: 100%;
        transition: border-color 0.2s;
    }

        .file-upload:hover {
            border-color: #79c0ff;
        }

        .file-upload::file-selector-button {
            background-color: #21262d;
            color: #c9d1d9;
            border: 1px solid #30363d;
            padding: 6px 14px;
            border-radius: 4px;
            margin-right: 16px;
            font-weight: 500;
            cursor: pointer;
            transition: background-color 0.2s, color 0.2s;
        }

            .file-upload::file-selector-button:hover {
                background-color: #30363d;
                color: #ffffff;
            }

    .updateBtn {
        background-color: #d29922;
        color: #ffffff;
        border: 1px solid rgba(240, 246, 252, 0.1);
        border-radius: 6px;
        padding: 10px 24px;
        font-weight: 600;
        transition: background-color 0.2s;
        width: 100%;
    }

        .updateBtn:hover {
            background-color: #e3b341;
            color: #ffffff;
        }

    .submitBtn {
        background-color: #238636;
        color: #ffffff;
        border: 1px solid rgba(240, 246, 252, 0.1);
        border-radius: 6px;
        padding: 10px 24px;
        font-weight: 600;
        transition: background-color 0.2s;
        width: 100%;
    }

        .submitBtn:hover {
            background-color: #2ea043;
            color: #ffffff;
        }

    .sys-message {
        background-color: rgba(35, 134, 54, 0.1);
        border: 1px solid #238636;
        color: #3fb950;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 20px;
        font-weight: 500;
    }

    .current-file-link {
        color: #58a6ff;
        text-decoration: none;
        font-weight: 500;
    }

        .current-file-link:hover {
            text-decoration: underline;
        }

    .backBtn {
        display: inline-block;
        margin-top: 24px;
        color: #8b949e;
        text-decoration: none;
        transition: color 0.2s;
        font-weight: 500;
    }

        .backBtn:hover {
            color: #58a6ff;
        }
</style>

<div class="row">
    <div class="col-12 d-flex justify-content-center">
        <div class="content-card">

            <form method="post" asp-action="Edit" enctype="multipart/form-data">

                @if (isAdmin)
                {
                    <h2><i class="bi bi-pencil-square text-warning"></i> Edit Assignment</h2>
                }
                else
                {
                    <h2><i class="bi bi-journal-arrow-up text-success"></i> Submit Assignment</h2>
                }
                <hr />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @if (ViewBag.Message != null)
                {
                    <div class="sys-message">
                        <i class="bi bi-check-circle"></i> @ViewBag.Message
                    </div>
                }

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ClassReferenceId" />
                <input type="hidden" asp-for="AnswerFilePath" />

                @if (isAdmin)
                {
                    <div class="form-group mb-3">
                        <label asp-for="Header" class="control-label"></label>
                        <input asp-for="Header" class="form-control textBox" />
                        <span asp-validation-for="Header" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Content" class="control-label"></label>
                        <textarea asp-for="Content" class="form-control textBox" rows="4"></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>
                }
                else
                {
                    <div class="form-group mb-3">
                        <label class="control-label"><i class="bi bi-card-heading"></i> Assignment Title</label>
                        <div class="read-only-box">@Model.Header</div>
                        <input type="hidden" asp-for="Header" />
                    </div>

                    <div class="form-group mb-4">
                        <label class="control-label"><i class="bi bi-card-text"></i> Instructions</label>
                        <div class="read-only-box">@Model.Content</div>
                        <input type="hidden" asp-for="Content" />
                    </div>
                }

                <div class="form-group mb-4">
                    <label asp-for="AnswerFile" class="control-label">
                        @if (isAdmin)
                        {
                            <span><i class="bi bi-cloud-upload"></i> Upload New Answer Key / File (Optional)</span>
                        }
                        else
                        {
                            <span><i class="bi bi-cloud-upload"></i> Upload Your Assignment Submission</span>
                        }
                    </label>
                    <input type="file" asp-for="AnswerFile" class="file-upload" />
                    <span asp-validation-for="AnswerFile" class="text-danger"></span>

                    @if (!string.IsNullOrEmpty(Model.AnswerFilePath))
                    {
                        <div class="mt-3 p-2 rounded" style="background-color: rgba(139, 148, 158, 0.1); border: 1px solid #30363d;">
                            <small class="text-muted d-block mb-1">
                                <i class="bi bi-file-earmark-check"></i> Current file:
                                <a href="@Model.AnswerFilePath" target="_blank" class="current-file-link">Download / View</a>
                            </small>
                            <small class="text-warning">
                                <i class="bi bi-exclamation-triangle"></i> <em>Note: Uploading a new file will replace the existing one.</em>
                            </small>
                        </div>
                    }
                </div>

                <div class="form-group mt-2">
                    @if (isAdmin)
                    {
                        <button type="submit" class="updateBtn"><i class="bi bi-save2"></i> Update Assignment</button>
                    }
                    else
                    {
                        <button type="submit" class="submitBtn"><i class="bi bi-send-check"></i> Submit File</button>
                    }
                </div>

                <div>
                    <a asp-action="Index" asp-route-classReferenceId="@Model.ClassReferenceId" class="backBtn">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}