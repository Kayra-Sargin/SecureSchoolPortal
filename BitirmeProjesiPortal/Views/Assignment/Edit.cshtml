@model BitirmeProjesiPortal.Models.Assignment

@{
    ViewData["Title"] = User.IsInRole("Admin") ? "Edit Assignment" : "Submit Assignment";
    bool isAdmin = User.IsInRole("Admin");
}

<style>
    .content-card {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-top: 4px solid transparent;
        background-clip: padding-box;
        border-radius: 8px;
        padding: 32px;
        width: 100%;
        max-width: 650px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        margin-top: 10px;
        position: relative;
    }

        .content-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            border-top-left-radius: 8px;
            border-top-right-radius: 8px;
        }

        .content-card.admin-mode::before {
            background: linear-gradient(135deg, #f59e0b, #d97706);
        }

        .content-card.student-mode::before {
            background: linear-gradient(135deg, #10b981, #059669);
        }

        .content-card h2 {
            color: #1e293b;
            font-size: 1.75rem;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .content-card hr {
            border-color: #e2e8f0;
            margin-bottom: 24px;
        }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group .control-label {
            color: #334155;
            margin-bottom: 8px;
            font-weight: 500;
            display: block;
        }

    .textBox {
        background-color: #ffffff !important;
        border: 1px solid #cbd5e1;
        color: #1e293b !important;
        border-radius: 6px;
        padding: 10px;
        transition: border-color 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .textBox:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
            outline: none;
        }

    .admin-mode .textBox:focus {
        border-color: #f59e0b;
        box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.2);
    }

    .student-mode .textBox:focus {
        border-color: #10b981;
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.2);
    }

    .read-only-box {
        background-color: #ffffff;
        border: 1px solid #cbd5e1;
        color: #1e293b;
        border-radius: 6px;
        padding: 12px;
        font-size: 0.95rem;
        line-height: 1.5;
    }

    .file-upload {
        background-color: #ffffff;
        border: 1px dashed #3b82f6;
        color: #475569;
        border-radius: 6px;
        padding: 8px;
        width: 100%;
        transition: border-color 0.2s;
    }

    .admin-mode .file-upload {
        border-color: #f59e0b;
    }

    .student-mode .file-upload {
        border-color: #10b981;
    }

    .file-upload:hover {
        border-color: #2563eb;
    }

    .admin-mode .file-upload:hover {
        border-color: #d97706;
    }

    .student-mode .file-upload:hover {
        border-color: #059669;
    }

    .file-upload::file-selector-button {
        background-color: #f1f5f9;
        color: #475569;
        border: 1px solid #cbd5e1;
        padding: 6px 14px;
        border-radius: 4px;
        margin-right: 16px;
        font-weight: 500;
        cursor: pointer;
        transition: background-color 0.2s, color 0.2s;
    }

        .file-upload::file-selector-button:hover {
            background-color: #e2e8f0;
            color: #1e293b;
        }

    .updateBtn {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: #ffffff;
        border: none;
        border-radius: 6px;
        padding: 10px 24px;
        font-weight: 600;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
        width: 100%;
        box-shadow: 0 4px 6px rgba(245, 158, 11, 0.2);
    }

        .updateBtn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 12px rgba(245, 158, 11, 0.3);
            color: #ffffff;
        }

    .submitBtn {
        background: linear-gradient(135deg, #10b981, #059669);
        color: #ffffff;
        border: none;
        border-radius: 6px;
        padding: 10px 24px;
        font-weight: 600;
        transition: transform 0.15s ease, box-shadow 0.15s ease;
        width: 100%;
        box-shadow: 0 4px 6px rgba(16, 185, 129, 0.2);
    }

        .submitBtn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 12px rgba(16, 185, 129, 0.3);
            color: #ffffff;
        }

    .sys-message {
        background-color: #ecfdf5;
        border: 1px solid #a7f3d0;
        color: #047857;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 20px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .current-file-link {
        color: #3b82f6;
        text-decoration: none;
        font-weight: 500;
    }

        .current-file-link:hover {
            text-decoration: underline;
            color: #2563eb;
        }

    .backBtn {
        display: inline-block;
        margin-top: 24px;
        color: #64748b;
        text-decoration: none;
        transition: color 0.2s;
        font-weight: 500;
    }

        .backBtn:hover {
            color: #3b82f6;
        }
</style>

<div class="row">
    <div class="col-12 d-flex justify-content-center">
        <div class="content-card @(isAdmin ? "admin-mode" : "student-mode")">

            <form method="post" asp-action="Edit" enctype="multipart/form-data">

                @if (isAdmin)
                {
                    <h2><i class="bi bi-pencil-square" style="color: #f59e0b;"></i> Edit Assignment</h2>
                }
                else
                {
                    <h2><i class="bi bi-journal-arrow-up" style="color: #10b981;"></i> Submit Assignment</h2>
                }
                <hr />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @if (ViewBag.Message != null)
                {
                    <div class="sys-message">
                        <i class="bi bi-check-circle-fill"></i> @ViewBag.Message
                    </div>
                }

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ClassReferenceId" />
                <input type="hidden" asp-for="AnswerFilePath" />

                @if (isAdmin)
                {
                    <div class="form-group mb-3">
                        <label asp-for="Header" class="control-label"></label>
                        <input asp-for="Header" class="form-control textBox" />
                        <span asp-validation-for="Header" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Content" class="control-label"></label>
                        <textarea asp-for="Content" class="form-control textBox" rows="4"></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>
                }
                else
                {
                    <div class="form-group mb-3">
                        <label class="control-label"><i class="bi bi-card-heading"></i> Assignment Title</label>
                        <div class="read-only-box">@Model.Header</div>
                        <input type="hidden" asp-for="Header" />
                    </div>

                    <div class="form-group mb-4">
                        <label class="control-label"><i class="bi bi-card-text"></i> Instructions</label>
                        <div class="read-only-box">@Model.Content</div>
                        <input type="hidden" asp-for="Content" />
                    </div>
                }

                <div class="form-group mb-4">
                    <label asp-for="AnswerFile" class="control-label">
                        @if (isAdmin)
                        {
                            <span><i class="bi bi-cloud-upload"></i> Upload New Answer Key / File (Optional)</span>
                        }
                        else
                        {
                            <span><i class="bi bi-cloud-upload"></i> Upload Your Assignment Submission</span>
                        }
                    </label>
                    <input type="file" asp-for="AnswerFile" class="file-upload" />
                    <span asp-validation-for="AnswerFile" class="text-danger"></span>

                    @if (!string.IsNullOrEmpty(Model.AnswerFilePath))
                    {
                        <div class="mt-3 p-3 rounded" style="background-color: #f1f5f9; border: 1px solid #e2e8f0;">
                            <small class="d-block mb-1" style="color: #475569;">
                                <i class="bi bi-file-earmark-check"></i> Current file:
                                <a href="@Model.AnswerFilePath" target="_blank" class="current-file-link">Download / View</a>
                            </small>
                            <small style="color: #d97706;">
                                <i class="bi bi-exclamation-triangle-fill"></i> <em>Note: Uploading a new file will replace the existing one.</em>
                            </small>
                        </div>
                    }
                </div>

                <div class="form-group mt-2">
                    @if (isAdmin)
                    {
                        <button type="submit" class="updateBtn"><i class="bi bi-save2"></i> Update Assignment</button>
                    }
                    else
                    {
                        <button type="submit" class="submitBtn"><i class="bi bi-send-check"></i> Submit File</button>
                    }
                </div>

                <div>
                    <a asp-action="Index" asp-route-classReferenceId="@Model.ClassReferenceId" class="backBtn">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}